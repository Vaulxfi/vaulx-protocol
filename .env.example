# Vaulx — root env template
#
# Copy this file to `.env.local` at the repo root and fill in values.
# `.env.local` is git-ignored. Never commit real keys.
#
# Variables prefixed with NEXT_PUBLIC_ are inlined into the browser bundle
# by Next.js and are safe to expose. All others are server-only.

# --- Supabase (server-only) ---
# Used by: packages/supabase/src/server.ts (service-role + user-scoped server clients),
# apps/web/src/app/api/** route handlers.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (browser-safe, mirrors of the above) ---
# Used by: packages/supabase/src/browser.ts (client components).
# Must equal SUPABASE_URL / SUPABASE_ANON_KEY respectively.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Helius RPC (server-only) ---
# Used by: apps/web server routes that need authenticated Solana RPC access
# (indexer sync, disburse-gate checks, audit log writers).
HELIUS_API_KEY=
