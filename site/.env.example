APP_NAME=Vaulx
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=garantifi
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Cross-origin demo embeds (iframe under partner domains) need
# `SESSION_SAME_SITE=none` and `SESSION_SECURE_COOKIE=true`. Defaults stay
# safe for dev — only flip them in prod where HTTPS is enforced.
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# --- GarantiFi --------------------------------------------------
GF_NETWORK=devnet
GF_RPC_URL=https://api.devnet.solana.com
GF_EXPLORER_URL=https://explorer.solana.com

GF_USDC_MINT=3eXFpUHRtg7UdJviTtz9LP87LfGk2aYsPDfkjDFai672
GF_BRZ_MINT=BRzSkMr57a72LNcBwpY2ZBpBMwDMsXbxjwRs4uPMZLG

GF_VAULT_PROGRAM_ID=
GF_LOAN_PROGRAM_ID=

GF_ANNUAL_BPS=2400
GF_LATE_FEE_BPS=150
GF_ORIGINATION_BPS=250

GF_RATE_SOURCE=awesomeapi
GF_RATE_CACHE_TTL=300
GF_FALLBACK_BRL_USD=5.18
GF_JUPITER_PRICE_URL=https://price.jup.ag/v6/price

# --- Feature flags (toggle as Anchor programs land) ------------------------
GF_ANCHOR_READY=false
GF_REAL_CNFT=false
GF_NOTIFICATIONS_ENABLED=true

# --- Locale & timezone -----------------------------------------------------
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=en
APP_DATE_FORMAT="d/m/Y"
APP_DATETIME_FORMAT="d/m/Y H:i"

# --- Demo magic-link (partner walkthrough) ---------------------------------
# Token gating GET /demo and POST /api/demo/reset. Generate with
# `openssl rand -hex 32` and keep out of source control. Empty value
# disables both endpoints (defensive default).
DEMO_MAGIC_TOKEN=
