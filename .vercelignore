# Allow-list approach: explicit "/*" denies everything at the root, then
# !rules un-deny just what the Next.js build needs.
/*

# What Vercel needs:
!apps
apps/*
!apps/web
!packages
!pnpm-workspace.yaml
!pnpm-lock.yaml
!package.json
!turbo.json
!tsconfig.base.json
!vercel.json

# Inside apps/web — strip dev artifacts
apps/web/.next/
apps/web/.turbo/
apps/web/node_modules/
apps/web/**/node_modules/

# Inside packages — strip dev artifacts
packages/*/node_modules/
packages/*/.turbo/
packages/*/dist/

# Always ignore
**/.git/
**/.DS_Store
**/*.log
!apps/web/public/demo/test-run.log
.env
.env.*.local
*.docx
*.pdf
*.png
*.html
00_*.md
01_*.md
02_*.md
03_*.md
GarantiFi*
LINEAR*
REPORT*
VAULX_*.md
VAULX_*.pdf
Vaulx*.docx
"Action Plan to be.md"
"vaulx meeting 1.md"
"vaulx-brand-vote*"
final_merged.csv
"Gemini_Generated*"
business-model*
edson_technical_brief*
garantifi-business*
garantifi-deck*
garantifi-spec*
"vaulx - logo simple.png"
