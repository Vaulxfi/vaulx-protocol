# vaulx-bridge — local development env
# Copy to .env and adjust as needed. Keep .env out of git.

# HTTP server
BRIDGE_PORT=8787

# Solana RPC the bridge talks to
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# REQUIRED — HMAC shared secret between Laravel and the bridge.
# Generate with: openssl rand -hex 32
# The bridge fails fast at boot if this is unset.
BRIDGE_SHARED_SECRET=

# HMAC freshness window in seconds. Defaults to 300 (±5min). Lower = stricter
# replay protection; higher = more tolerance for clock drift between Laravel
# and bridge hosts.
# BRIDGE_HMAC_FRESHNESS_SECONDS=300

# Path to the operator's Solana keypair JSON (the keypair that signs
# protocol-side ixs: confirm_custody, sas/issue, execute_af_default
# proposals). Defaults to the user's solana CLI keypair.
# OPERATOR_KEYPAIR_PATH=~/.config/solana/id.json
