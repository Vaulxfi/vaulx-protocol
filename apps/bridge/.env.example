# vaulx-bridge — local development env
# Copy to .env and adjust as needed. Keep .env out of git.

# HTTP server
BRIDGE_PORT=8787

# Solana RPC the bridge talks to
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# --- Wired in subsequent commits, not consumed by the skeleton ---
# HMAC shared secret between Laravel and the bridge. Generate with
# `openssl rand -hex 32`. Server-side only.
# BRIDGE_SHARED_SECRET=

# Path to the operator's Solana keypair JSON (the keypair that signs
# protocol-side ixs: confirm_custody, sas/issue, execute_af_default
# proposals). Defaults to the user's solana CLI keypair if unset.
# OPERATOR_KEYPAIR_PATH=~/.config/solana/id.json
