SOLANA_RPC_URL=https://api.devnet.solana.com
SUPABASE_URL=https://ctiypfxtymnszposgaky.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- RedStone-pattern price publisher (Item 5) ---
# Absolute path to the Vaulx oracle-admin keypair (Solana JSON keypair file).
# When unset, the publisher does not start and the loan program runs in
# legacy-appraisal mode (oracle_admin == default). The keypair MUST also be
# bound on-chain via `loan::set_oracle_admin` before the program will accept
# its publications. Never commit this file. SR-4.
REDSTONE_SIGNER_KEYPAIR_PATH=

# Base URL for the appraisal endpoint (default http://localhost:3000).
APPRAISAL_BASE_URL=http://localhost:3000

# Pipe-delimited 5-tuples (make|model|ref|year|condition), comma-separated.
# Example:
#   REDSTONE_WATCHED_REFS=Rolex|Submariner|126610LN|2024|excellent,Patek|Nautilus|5711|2023|excellent
REDSTONE_WATCHED_REFS=

# --- GraphQL endpoint over Supabase event log (Item 6) ---
# Port for the read-only GraphQL server exposed by the indexer. Set to 0 to
# disable. Default 4000.
GRAPHQL_PORT=4000

# --- Kamino USDC float yield routing (Item 7) ---
# DRY-RUN by default. Real execution requires a vault.route_idle_to_kamino
# Anchor ix that CPIs Kamino with PDA signing. Until that lands, the router
# observes idle USDC and logs the routing action it would have taken.
#
# Set ALL of: KAMINO_VAULT_ADDRESS + KAMINO_SIGNER_KEYPAIR_PATH +
# KAMINO_VAULT_PDA + KAMINO_VAULT_USDC_ACCOUNT to enable. Leave any unset to
# disable. SR-1: KAMINO_VAULT_ADDRESS must match the canonical pubkey
# hardcoded in apps/indexer/src/kamino-router.ts.
# KAMINO_VAULT_ADDRESS=
# KAMINO_SIGNER_KEYPAIR_PATH=~/.config/vaulx/kamino-signer.json
# KAMINO_VAULT_PDA=
# KAMINO_VAULT_USDC_ACCOUNT=
# KAMINO_CLUSTER=mainnet  # or devnet (devnet has no canonical vault — router refuses to start)
# KAMINO_DRY_RUN=true     # default; flip to false ONLY after vault.route_idle_to_kamino ix lands
# KAMINO_OUTSTANDING_LOANS_USDC_BASE=0  # u64 base units (6 decimals); default 0 (treat full balance as idle)
