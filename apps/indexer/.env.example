SOLANA_RPC_URL=https://api.devnet.solana.com
SUPABASE_URL=https://ctiypfxtymnszposgaky.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- RedStone-pattern price publisher (Item 5) ---
# Absolute path to the Vaulx oracle-admin keypair (Solana JSON keypair file).
# When unset, the publisher does not start and the loan program runs in
# legacy-appraisal mode (oracle_admin == default). The keypair MUST also be
# bound on-chain via `loan::set_oracle_admin` before the program will accept
# its publications. Never commit this file. SR-4.
REDSTONE_SIGNER_KEYPAIR_PATH=

# Base URL for the appraisal endpoint (default http://localhost:3000).
APPRAISAL_BASE_URL=http://localhost:3000

# Pipe-delimited 5-tuples (make|model|ref|year|condition), comma-separated.
# Example:
#   REDSTONE_WATCHED_REFS=Rolex|Submariner|126610LN|2024|excellent,Patek|Nautilus|5711|2023|excellent
REDSTONE_WATCHED_REFS=
