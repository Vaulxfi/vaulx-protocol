# apps/web — Next.js env template
#
# Copy to `apps/web/.env.local` and fill in. `.env.local` is git-ignored.
# Variables prefixed with NEXT_PUBLIC_ are inlined into the browser bundle
# by Next.js at build time and are safe to expose to the client.
# All other variables are server-only (route handlers, server components).

# --- Solana RPC (client-safe) ---
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_CLUSTER=devnet

# USDC SPL mint on the active cluster. For Devnet, populate from
# `scripts/dev/devnet-usdc.json` after running the seed-usdc script.
NEXT_PUBLIC_USDC_MINT=

# --- Supabase (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only, never expose to browser) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Helius RPC (server-only) ---
HELIUS_API_KEY=

# --- WatchCharts API (server-only) ---
# If unset, the appraisal route falls back to bundled fixture data.
# WATCHCHARTS_API_KEY=

# --- Apify Chrono24 actor (server-only) ---
# Apify Chrono24 actor — production-grade Chrono24 scrape.
# Get from console.apify.com → API tokens.
# When set, replaces the fallback HTML scraper at lib/appraisal/chrono24.ts.
# APIFY_API_TOKEN=
#
# Override the actor id if Apify renames/moves the actor in the Store.
# Default: apify/chrono24-scraper
# APIFY_CHRONO24_ACTOR_ID=apify/chrono24-scraper

# Civic Auth (OAuth / OIDC). Get client id from auth.civic.com/dashboard.
# Free tier; SOC 2 Type 1 certified.
# NEXT_PUBLIC_CIVIC_AUTH_CLIENT_ID=

# --- Solana Pay (client-safe) ---
# Public origin the web app is reachable at — used to build Solana Pay
# "transaction request" URLs embedded in QR codes. Mobile wallets reject
# http:// links unless the host is `localhost`, so for real-device testing
# this must be an HTTPS URL (ngrok / Vercel preview / deployed domain).
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Crossmint smart-wallet integration (Phase A — staging env) ---
# Email / Google / Apple → Solana smart wallet, no seed phrase, email recovery.
#
# Get a CLIENT API key from staging.crossmint.com → Console → API Keys.
# Staging is FREE, INSTANT, NO KYC. Solana Devnet is auto-selected by the SDK
# when `chain: "solana"` is passed and the key is `ck_staging_*`. Test USDXM
# is mintable on Devnet via `wallet.stagingFund(amount)` for end-to-end demos.
#
# The SDK has NO explicit `environment` prop — the API-key prefix routes:
#   ck_staging_*    → https://staging.crossmint.com/  (Devnet, free)
#   ck_production_* → https://www.crossmint.com/      (Mainnet, KYC required)
# We still expose NEXT_PUBLIC_CROSSMINT_ENV so a misconfigured key (prod key
# with env=staging) fails closed to mock rather than routing to mainnet.
#
# When NEXT_PUBLIC_CROSSMINT_ENV is unset OR set to "mock": the demo runs in
# clearly-labeled mock mode (1.5s simulated provisioning, MockBadge visible).
# NEXT_PUBLIC_CROSSMINT_API_KEY=ck_staging_...
# NEXT_PUBLIC_CROSSMINT_ENV=staging   # or "production" with ck_production_... key

# --- Admin (/admin/tests live SSE test runner) ---
# If set, /admin/* routes (notably /api/admin/tests/stream which spawns
# `anchor test`) require the request to carry a matching `vaulx-admin` cookie
# or `x-vaulx-admin` header. Leave unset during the hackathon demo so judges
# can view /admin/tests live. Production MUST set this to a real admin pubkey
# and front the routes with a proper auth check.
# NEXT_PUBLIC_VAULX_ADMIN_PUBKEY=
